{
  "_meta": {
    "version": 1,
    "description": "各银行流水到统一交易明细模板的转换规则。debit_credit_mode 取值: two_columns / signed_amount / marker_column",
    "template_headers": [
      "交易后余额", "账户名称", "账户性质", "银行账号", "关联客户号",
      "银行流水号", "交易日期", "银行类型", "对账码", "币种",
      "摘要", "业务参考号", "借方金额", "贷方金额", "客商名称",
      "客商编号", "开户行名称", "对方账号", "对方户名", "对方开户行",
      "款项性质代码", "用途", "备注", "交易流水号", "单位名称",
      "起息日", "借/贷金额"
    ]
  },

  "招商银行": {
    "bank_type_code": "CMB",
    "header_row": 1,
    "skip_top_rows": 0,
    "debit_credit_mode": "two_columns",
    "column_mapping": {
      "交易日期": {"source": "交易时间", "in_fmt": "%Y-%m-%d %H:%M:%S", "out_fmt": "%Y-%m-%d %H:%M:%S"},
      "交易后余额": "余额",
      "借方金额": "借方发生额",
      "贷方金额": "贷方发生额",
      "对方账号": "对方账号",
      "对方户名": "对方户名",
      "摘要": "摘要",
      "用途": "用途"
    },
    "fixed_values": {"币种": "10"}
  },

